# Copy to `.env` (which is gitignored) and fill in. Never commit real values.

# Inference backend. Unset (or "ollama") = free local models via Ollama (dev default).
# "cf" = Cloudflare Workers AI, using each persona's cf_model (production).
# CROWD_BACKEND=cf

# Optional — better web_search results for the bots (else a keyless DuckDuckGo fallback).
# TAVILY_API_KEY=tvly-...

# Cloudflare Workers AI — powers the bots when CROWD_BACKEND=cf.
# Account ID: dash.cloudflare.com -> right sidebar "Account ID".
# Token:      dash -> AI -> Workers AI -> "Use REST API", or a custom token with
#             permission Account · Workers AI · Read.
CF_ACCOUNT_ID=your_account_id_here
CF_API_TOKEN=your_workers_ai_token_here

# Optional — only the @haiku bot needs this (paid). Leave unset and @haiku stays silent.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Production (Fly) -------------------------------------------------------
# These are NOT read from .env in production (no .env file ships in the image) —
# set them via fly.toml [env] (non-secret) or `fly secrets set` (CF_ACCOUNT_ID,
# CF_API_TOKEN, etc.), same names as above. Listed here for reference only:
#
#   CROWD_BACKEND=cf                                  # no Ollama on Fly
#   TOWNSQUARE_WS_URL=wss://josefrichter-townsquare.fly.dev
#   TOWNSQUARE_ORIGIN=https://josefrichter.design      # must match the server's allowlist
#   PORT=8080                                          # the status server (/healthz)
